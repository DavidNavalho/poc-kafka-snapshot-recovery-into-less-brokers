#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/../../.." && pwd -P)/automation/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="scenario-05"
run_id="${1:-}"

[[ -n "${run_id}" ]] || fail "usage: automation/scenarios/scenario-05/report <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"

summary_path="${WORKDIR}/artifacts/assert/assert-summary.json"
snapshot_manifest_path="${WORKDIR}/snapshot-manifest.json"
report_date="$(date -u +%F)"
report_path="${REPORT_RUNS_ROOT}/${report_date}-scenario-05-${run_id}.md"
recovery_image="$(jq -r '.image.vendor + "/" + .image.product + ":" + .image.tag' "${snapshot_manifest_path}")"
source_fixture_version="$(jq -r '.source_fixture_version // "unknown"' "${snapshot_manifest_path}")"
summary_status="$(jq -r '.status // "fail"' "${summary_path}")"
docker_server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || printf 'unknown')"
docker_compose_version="$(docker compose version --short 2>/dev/null || printf 'unknown')"
host_machine="$(hostname)"

readonly CONFIGURED_TOPICS=(
  "recovery.retention.short"
  "recovery.retention.long"
  "recovery.compacted.accounts"
  "recovery.compacted.orders"
  "recovery.compressed.zstd"
)

readonly ZERO_OVERRIDE_TOPICS=(
  "recovery.default.6p"
  "recovery.default.12p"
  "recovery.default.24p"
  "recovery.txn.test"
  "recovery.consumer.test"
)

case "${summary_status}" in
  pass) result_label="PASS" ;;
  fail) result_label="FAIL" ;;
  *) result_label="PARTIAL" ;;
esac

assertions_table="$(
  jq -r '.assertions[] | [.name, .result, .evidence] | @tsv' "${summary_path}" | while IFS=$'\t' read -r name result evidence; do
    printf '| %s | %s | `%s` |\n' "${name}" "${result}" "${evidence}"
  done
)"

configured_topics_block="$(
  for topic_name in "${CONFIGURED_TOPICS[@]}"; do
    printf -- '- `%s`\n' "${topic_name}"
  done
)"

zero_override_topics_block="$(
  for topic_name in "${ZERO_OVERRIDE_TOPICS[@]}"; do
    printf -- '- `%s`\n' "${topic_name}"
  done
)"

findings_block="- none"
if [[ "${summary_status}" != "pass" ]]; then
  findings_block="$(
    jq -r '.assertions[] | select(.result != "PASS") | "- " + .name + ": " + (.details // "no details")' "${summary_path}"
  )"
fi

follow_up_block="- Investigate the failing config comparisons before proceeding."
if [[ "${summary_status}" == "pass" ]]; then
  follow_up_block="- Proceed to Scenario 08."
fi

ensure_dir "${REPORT_RUNS_ROOT}"

cat >"${report_path}" <<EOF
# Scenario 05 Report

## Summary

- Scenario: scenario-05
- Run ID: ${run_id}
- Date: ${report_date}
- Snapshot label: ${SNAPSHOT_LABEL}
- Source fixture revision: ${source_fixture_version}
- Recovery image version: ${recovery_image}
- Result: ${result_label}

## Environment

- Host machine: ${host_machine}
- Docker version: ${docker_server_version}
- Compose version: ${docker_compose_version}
- Relevant resource notes: scenario report generated from ${WORKDIR}

## Procedure

1. \`automation/recovery/prepare scenario-05 ${SNAPSHOT_LABEL} ${run_id}\`
2. \`automation/recovery/rewrite scenario-05 ${run_id}\`
3. \`automation/recovery/up scenario-05 ${run_id}\`
4. \`automation/scenarios/scenario-05/assert ${run_id}\`
5. \`automation/scenarios/scenario-05/report ${run_id}\`

## Configuration Scope

- Configured topics:
${configured_topics_block}
- Zero-override topics:
${zero_override_topics_block}
- In-scope brokers: \`0\`, \`1\`, \`2\`

## Assertions

| Assertion | Result | Evidence |
|---|---|---|
${assertions_table}

## Artifacts

- Topic config dumps: \`${WORKDIR}/artifacts/assert/topics/\`
- Broker config dumps: \`${WORKDIR}/artifacts/assert/brokers/\`
- Recovery logs: \`${WORKDIR}/artifacts/recovery/docker-compose.log\`
- Recovery compose state: \`${WORKDIR}/artifacts/assert/recovery-ps.txt\`

## Findings

${findings_block}

## Follow-Up

${follow_up_block}
EOF

log "scenario 05 report written to ${report_path}"
