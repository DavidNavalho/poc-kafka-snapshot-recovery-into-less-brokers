#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/../../.." && pwd -P)/automation/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="scenario-08"
run_id="${1:-}"

[[ -n "${run_id}" ]] || fail "usage: automation/scenarios/scenario-08/report <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"

summary_path="${WORKDIR}/artifacts/assert/assert-summary.json"
snapshot_manifest_path="${WORKDIR}/snapshot-manifest.json"
report_date="$(date -u +%F)"
report_path="${REPORT_RUNS_ROOT}/${report_date}-scenario-08-${run_id}.md"
recovery_image="$(jq -r '.image.vendor + "/" + .image.product + ":" + .image.tag' "${snapshot_manifest_path}")"
source_fixture_version="$(jq -r '.source_fixture_version // "unknown"' "${snapshot_manifest_path}")"
summary_status="$(jq -r '.status // "fail"' "${summary_path}")"
docker_server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || printf 'unknown')"
docker_compose_version="$(docker compose version --short 2>/dev/null || printf 'unknown')"
host_machine="$(hostname)"

readonly BROKERS=(0 1 2)
readonly LOGDIR_NAMES=("logdir-0" "logdir-1")
readonly REPRESENTATIVE_TOPIC="recovery.default.6p"

case "${summary_status}" in
  pass) result_label="PASS" ;;
  fail) result_label="FAIL" ;;
  *) result_label="PARTIAL" ;;
esac

assertions_table="$(
  jq -r '.assertions[] | [.name, .result, .evidence] | @tsv' "${summary_path}" | while IFS=$'\t' read -r name result evidence; do
    printf '| %s | %s | `%s` |\n' "${name}" "${result}" "${evidence}"
  done
)"

logdir_scope_block="$(
  for broker_id in "${BROKERS[@]}"; do
    for logdir_name in "${LOGDIR_NAMES[@]}"; do
      recovered_listing="${WORKDIR}/artifacts/assert/logdirs/broker-${broker_id}.${logdir_name}.recovered-partitions.txt"
      partition_count="unknown"
      if [[ -f "${recovered_listing}" ]]; then
        partition_count="$(wc -l <"${recovered_listing}" | tr -d '[:space:]')"
      fi
      printf -- '- broker `%s`, `%s`: `%s` user partition directories\n' "${broker_id}" "${logdir_name}" "${partition_count}"
    done
  done
)"

findings_block="- none"
if [[ "${summary_status}" != "pass" ]]; then
  findings_block="$(
    jq -r '.assertions[] | select(.result != "PASS") | "- " + .name + ": " + (.details // "no details")' "${summary_path}"
  )"
fi

follow_up_block="- Investigate the failing multi-disk assertions before proceeding."
if [[ "${summary_status}" == "pass" ]]; then
  follow_up_block="- Proceed to Scenario 04."
fi

ensure_dir "${REPORT_RUNS_ROOT}"

cat >"${report_path}" <<EOF
# Scenario 08 Report

## Summary

- Scenario: scenario-08
- Run ID: ${run_id}
- Date: ${report_date}
- Snapshot label: ${SNAPSHOT_LABEL}
- Source fixture revision: ${source_fixture_version}
- Recovery image version: ${recovery_image}
- Result: ${result_label}

## Environment

- Host machine: ${host_machine}
- Docker version: ${docker_server_version}
- Compose version: ${docker_compose_version}
- Relevant resource notes: scenario report generated from ${WORKDIR}

## Procedure

1. \`automation/recovery/prepare scenario-08 ${SNAPSHOT_LABEL} ${run_id}\`
2. \`automation/recovery/rewrite scenario-08 ${run_id}\`
3. \`automation/recovery/up scenario-08 ${run_id}\`
4. \`automation/scenarios/scenario-08/assert ${run_id}\`
5. \`automation/scenarios/scenario-08/report ${run_id}\`

## Multi-Disk Scope

- Snapshot source root: \`${SNAPSHOT_SOURCE_ROOT}\`
- In-scope recovery log dirs: \`logdir-0\`, \`logdir-1\`
- Representative readability topic: \`${REPRESENTATIVE_TOPIC}\`
- Recovered user partition directory counts:
${logdir_scope_block}

## Assertions

| Assertion | Result | Evidence |
|---|---|---|
${assertions_table}

## Artifacts

- Source and recovered logdir listings: \`${WORKDIR}/artifacts/assert/logdirs/\`
- Meta.properties extracts: \`${WORKDIR}/artifacts/assert/meta/\`
- Stray and startup failure scans: \`${WORKDIR}/artifacts/assert/stray-scan.txt\`, \`${WORKDIR}/artifacts/assert/startup-failure-scan.txt\`
- Topic describe output: \`${WORKDIR}/artifacts/assert/topics/\`
- Sample consume outputs: \`${WORKDIR}/artifacts/assert/samples/\`
- Recovery logs: \`${WORKDIR}/artifacts/recovery/docker-compose.log\`

## Findings

${findings_block}

## Follow-Up

${follow_up_block}
EOF

log "scenario 08 report written to ${report_path}"
