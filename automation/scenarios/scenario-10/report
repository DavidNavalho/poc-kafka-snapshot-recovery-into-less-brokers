#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/../../.." && pwd -P)/automation/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="scenario-10"
run_id="${1:-}"

[[ -n "${run_id}" ]] || fail "usage: automation/scenarios/scenario-10/report <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"

summary_path="${WORKDIR}/artifacts/assert/assert-summary.json"
snapshot_manifest_path="${WORKDIR}/snapshot-manifest.json"
report_date="$(date -u +%F)"
report_path="${REPORT_RUNS_ROOT}/${report_date}-scenario-10-${run_id}.md"
recovery_image="$(jq -r '.image.vendor + "/" + .image.product + ":" + .image.tag' "${snapshot_manifest_path}")"
source_fixture_version="$(jq -r '.source_fixture_version // "unknown"' "${snapshot_manifest_path}")"
summary_status="$(jq -r '.status // "fail"' "${summary_path}")"
docker_server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || printf 'unknown')"
docker_compose_version="$(docker compose version --short 2>/dev/null || printf 'unknown')"
host_machine="$(hostname)"

readonly TARGET_TOPIC="recovery.default.6p"
readonly TARGET_PARTITIONS=(0 1 2)

case "${summary_status}" in
  pass) result_label="PASS" ;;
  fail) result_label="FAIL" ;;
  *) result_label="PARTIAL" ;;
esac

assertions_table="$(
  jq -r '.assertions[] | [.name, .result, .evidence] | @tsv' "${summary_path}" | while IFS=$'\t' read -r name result evidence; do
    printf '| %s | %s | `%s` |\n' "${name}" "${result}" "${evidence}"
  done
)"

partition_counts_block="$(
  for partition_id in "${TARGET_PARTITIONS[@]}"; do
    count_path="${WORKDIR}/artifacts/assert/samples/${TARGET_TOPIC}.p${partition_id}.count.txt"
    if [[ -f "${count_path}" ]]; then
      count_value="$(tr -d '[:space:]' <"${count_path}")"
    else
      count_value="missing"
    fi
    printf -- '- partition `%s`: `%s`\n' "${partition_id}" "${count_value}"
  done
)"

transient_underrep_block="not observed"
if [[ -s "${WORKDIR}/artifacts/assert/reassignment/under-replicated.during.txt" ]]; then
  transient_underrep_block="observed"
fi

findings_block="- none"
if [[ "${summary_status}" != "pass" ]]; then
  findings_block="$(
    jq -r '.assertions[] | select(.result != "PASS") | "- " + .name + ": " + (.details // "no details")' "${summary_path}"
  )"
fi

follow_up_block="- Investigate the failing reassignment or post-expansion assertions before continuing."
if [[ "${summary_status}" == "pass" ]]; then
  follow_up_block="- Proceed to Scenario 11."
fi

ensure_dir "${REPORT_RUNS_ROOT}"

cat >"${report_path}" <<EOF
# Scenario 10 Report

## Summary

- Scenario: scenario-10
- Run ID: ${run_id}
- Date: ${report_date}
- Snapshot label: ${SNAPSHOT_LABEL}
- Source fixture revision: ${source_fixture_version}
- Recovery image version: ${recovery_image}
- Result: ${result_label}

## Environment

- Host machine: ${host_machine}
- Docker version: ${docker_server_version}
- Compose version: ${docker_compose_version}
- Relevant resource notes: scenario report generated from ${WORKDIR}

## Procedure

1. \`automation/recovery/prepare scenario-10 ${SNAPSHOT_LABEL} ${run_id}\`
2. \`automation/recovery/rewrite scenario-10 ${run_id}\`
3. \`automation/recovery/up scenario-10 ${run_id}\`
4. \`automation/scenarios/scenario-10/assert ${run_id}\`
5. \`automation/scenarios/scenario-10/report ${run_id}\`

## Expansion Scope

- Target topic: \`${TARGET_TOPIC}\`
- Target partitions: \`0,1,2\`
- Target post-expansion replicas: \`[0,1,2]\`
- Transient under-replication during polling: ${transient_underrep_block}
- Post-expansion partition counts:
${partition_counts_block}

## Assertions

| Assertion | Result | Evidence |
|---|---|---|
${assertions_table}

## Artifacts

- Pre and post topic describes: \`${WORKDIR}/artifacts/assert/topics/\`
- Reassignment payload and execute output: \`${WORKDIR}/artifacts/assert/reassignment/\`
- Post-expansion partition counts: \`${WORKDIR}/artifacts/assert/samples/\`
- Recovery logs: \`${WORKDIR}/artifacts/recovery/docker-compose.log\`

## Findings

${findings_block}

## Follow-Up

${follow_up_block}
EOF

log "scenario 10 report written to ${report_path}"
