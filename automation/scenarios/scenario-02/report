#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/../../.." && pwd -P)/automation/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="scenario-02"
run_id="${1:-}"

[[ -n "${run_id}" ]] || fail "usage: automation/scenarios/scenario-02/report <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"

summary_path="${WORKDIR}/artifacts/assert/assert-summary.json"
snapshot_manifest_path="${WORKDIR}/snapshot-manifest.json"
report_date="$(date -u +%F)"
report_path="${REPORT_RUNS_ROOT}/${report_date}-scenario-02-${run_id}.md"
corruption_scan_path="${WORKDIR}/artifacts/assert/corruption-scan.txt"
recovery_image="$(jq -r '.image.vendor + "/" + .image.product + ":" + .image.tag' "${snapshot_manifest_path}")"
source_fixture_version="$(jq -r '.source_fixture_version // "unknown"' "${snapshot_manifest_path}")"
summary_status="$(jq -r '.status // "fail"' "${summary_path}")"
docker_server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || printf 'unknown')"
docker_compose_version="$(docker compose version --short 2>/dev/null || printf 'unknown')"
host_machine="$(hostname)"

case "${summary_status}" in
  pass) result_label="PASS" ;;
  fail) result_label="FAIL" ;;
  *) result_label="PARTIAL" ;;
esac

assertions_table="$(
  jq -r '.assertions[] | [.name, .result, .evidence] | @tsv' "${summary_path}" | while IFS=$'\t' read -r name result evidence; do
    printf '| %s | %s | `%s` |\n' "${name}" "${result}" "${evidence}"
  done
)"

findings_block="- none"
if [[ -s "${corruption_scan_path}" ]] && ! grep -q '^no corruption patterns detected$' "${corruption_scan_path}"; then
  findings_block="$(while IFS= read -r line; do printf -- '- %s\n' "${line}"; done <"${corruption_scan_path}")"
fi

follow_up_block="- Investigate the failing assertions and recovery logs before proceeding."
if [[ "${summary_status}" == "pass" ]]; then
  follow_up_block="- Proceed to Scenario 05."
fi

ensure_dir "${REPORT_RUNS_ROOT}"

cat >"${report_path}" <<EOF
# Scenario 02 Report

## Summary

- Scenario: scenario-02
- Run ID: ${run_id}
- Date: ${report_date}
- Snapshot label: ${SNAPSHOT_LABEL}
- Source fixture revision: ${source_fixture_version}
- Recovery image version: ${recovery_image}
- Result: ${result_label}

## Environment

- Host machine: ${host_machine}
- Docker version: ${docker_server_version}
- Compose version: ${docker_compose_version}
- Relevant resource notes: scenario report generated from ${WORKDIR}

## Procedure

1. \`automation/recovery/prepare scenario-02 ${SNAPSHOT_LABEL} ${run_id}\`
2. \`automation/recovery/rewrite scenario-02 ${run_id}\`
3. \`automation/recovery/up scenario-02 ${run_id}\`
4. \`automation/scenarios/scenario-02/assert ${run_id}\`
5. \`automation/scenarios/scenario-02/report ${run_id}\`

## Representative Scope

- Representative topics: \`recovery.default.6p\`, \`recovery.default.12p\`, \`recovery.default.24p\`, \`recovery.compressed.zstd\`
- Sampled partitions:
  - \`recovery.default.6p\`: \`0\`, \`5\`
  - \`recovery.default.12p\`: \`0\`, \`11\`
  - \`recovery.default.24p\`: \`0\`, \`23\`
  - \`recovery.compressed.zstd\`: \`0\`, \`11\`

## Assertions

| Assertion | Result | Evidence |
|---|---|---|
${assertions_table}

## Artifacts

- Broker logs: \`${WORKDIR}/artifacts/recovery/docker-compose.log\`
- Topic descriptions: \`${WORKDIR}/artifacts/assert/topics/\`
- Offset outputs: \`${WORKDIR}/artifacts/assert/offsets/\`
- Sample counts and previews: \`${WORKDIR}/artifacts/assert/samples/\`
- Other: \`${WORKDIR}/artifacts/assert/corruption-scan.txt\`

## Findings

${findings_block}

## Follow-Up

${follow_up_block}
EOF

log "scenario 02 report written to ${report_path}"
