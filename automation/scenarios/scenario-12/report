#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/../../.." && pwd -P)/automation/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="scenario-12"
run_id="${1:-}"

[[ -n "${run_id}" ]] || fail "usage: automation/scenarios/scenario-12/report <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"

manifest_path="${REPEATABILITY_MANIFEST_PATH:-${WORKDIR}/artifacts/repeatability-manifest.json}"
summary_path="${WORKDIR}/artifacts/assert/assert-summary.json"
report_date="$(date -u +%F)"
report_path="${REPORT_RUNS_ROOT}/${report_date}-scenario-12-${run_id}.md"
summary_status="$(jq -r '.status // "fail"' "${summary_path}")"
docker_server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || printf 'unknown')"
docker_compose_version="$(docker compose version --short 2>/dev/null || printf 'unknown')"
host_machine="$(hostname)"

case "${summary_status}" in
  pass) result_label="PASS" ;;
  fail) result_label="FAIL" ;;
  *) result_label="PARTIAL" ;;
esac

assertions_table="$(
  jq -r '.assertions[] | [.name, .result, .evidence] | @tsv' "${summary_path}" | while IFS=$'\t' read -r name result evidence; do
    printf '| %s | %s | `%s` |\n' "${name}" "${result}" "${evidence}"
  done
)"

findings_block="- none"
if [[ "${summary_status}" != "pass" ]]; then
  findings_block="$(
    jq -r '.assertions[] | select(.result != "PASS") | "- " + .name + ": " + (.details // "no details")' "${summary_path}"
  )"
fi

follow_up_block="- Investigate the differing normalized bundles before trusting the suite as repeatable."
if [[ "${summary_status}" == "pass" ]]; then
  follow_up_block="- The clean-stop suite is now repeatable; only Scenario 09 remains deferred."
fi

ensure_dir "${REPORT_RUNS_ROOT}"

cat >"${report_path}" <<EOF
# Scenario 12 Report

## Summary

- Scenario: scenario-12
- Run ID: ${run_id}
- Date: ${report_date}
- Snapshot label: ${SNAPSHOT_LABEL}
- Result: ${result_label}

## Environment

- Host machine: ${host_machine}
- Docker version: ${docker_server_version}
- Compose version: ${docker_compose_version}
- Relevant resource notes: repeatability report generated from ${WORKDIR}

## Procedure

1. \`automation/scenarios/scenario-12/run ${SNAPSHOT_LABEL} ${run_id}\`
2. Scenario 11 suite run 1: \`$(jq -r '.run1.suite_run_id' "${manifest_path}")\`
3. Scenario 11 suite run 2: \`$(jq -r '.run2.suite_run_id' "${manifest_path}")\`
4. normalized bundles compared under \`${WORKDIR}/artifacts/normalized/\`
5. \`automation/scenarios/scenario-12/assert ${run_id}\`
6. \`automation/scenarios/scenario-12/report ${run_id}\`

## Assertions

| Assertion | Result | Evidence |
|---|---|---|
${assertions_table}

## Repeatability Runs

- Run 1 suite ID: \`$(jq -r '.run1.suite_run_id' "${manifest_path}")\`
- Run 1 suite status: \`$(jq -r '.run1.status' "${manifest_path}")\`
- Run 1 suite manifest: \`$(jq -r '.run1.suite_manifest_path' "${manifest_path}")\`
- Run 1 normalized bundle: \`$(jq -r '.run1.bundle_path' "${manifest_path}")\`
- Run 2 suite ID: \`$(jq -r '.run2.suite_run_id' "${manifest_path}")\`
- Run 2 suite status: \`$(jq -r '.run2.status' "${manifest_path}")\`
- Run 2 suite manifest: \`$(jq -r '.run2.suite_manifest_path' "${manifest_path}")\`
- Run 2 normalized bundle: \`$(jq -r '.run2.bundle_path' "${manifest_path}")\`

## Artifacts

- Repeatability manifest: \`${manifest_path}\`
- Normalized bundle 1: \`${WORKDIR}/artifacts/normalized/run1.bundle.json\`
- Normalized bundle 2: \`${WORKDIR}/artifacts/normalized/run2.bundle.json\`
- Normalized diff: \`${WORKDIR}/artifacts/normalized/diff.txt\`

## Findings

${findings_block}

## Follow-Up

${follow_up_block}
EOF

log "scenario 12 report written to ${report_path}"
