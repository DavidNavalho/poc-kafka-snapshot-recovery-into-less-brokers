#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")/.." && pwd -P)/lib/common.sh"

require_cmd docker
require_cmd jq

scenario_id="${1:-}"
run_id="${2:-}"

[[ -n "${scenario_id}" && -n "${run_id}" ]] || fail "usage: automation/recovery/up <scenario-id> <run-id>"

run_env_path="${SCENARIO_RUNS_ROOT}/${scenario_id}/${run_id}/run.env"
load_run_env "${run_env_path}"
export RECOVERY_WORKDIR

selected_checkpoint_basename="$(jq -r '.basename' "${SELECTED_CHECKPOINT_JSON}")"
for broker_id in 0 1 2; do
  checkpoint_path="$(metadata_snapshot_dir "${WORKDIR}/brokers/broker-${broker_id}/metadata")/${selected_checkpoint_basename}"
  [[ -f "${checkpoint_path}" ]] || fail "rewritten checkpoint not installed for broker ${broker_id}: ${checkpoint_path}"
done

log "starting recovery cluster ${RECOVERY_PROJECT}"
recovery_compose "${RECOVERY_PROJECT}" up -d
wait_for_recovery_cluster "${RECOVERY_PROJECT}"
log "recovery cluster ${RECOVERY_PROJECT} is ready"
